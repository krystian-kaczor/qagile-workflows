    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const bodyRaw = $json.body || '';\nlet body = '';\nif (typeof bodyRaw === 'string') {\n  body = bodyRaw;\n} else if (bodyRaw && bodyRaw.content) {\n  body = String(bodyRaw.content);\n} else if (bodyRaw) {\n  body = JSON.stringify(bodyRaw);\n}\n\nconst plainUrlPattern = /https?:\\/\\/[^\\s<>\"']+/gi;\nconst matches = body.match(plainUrlPattern);\nconst allUrls = matches ? matches : [];\n\nconst objectReturned = {json: {\n    messageId : $json.id,\n    links: allUrls\n  }\n}\n\nreturn objectReturned"
      },
