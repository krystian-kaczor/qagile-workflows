    {
      "parameters": {
        "jsCode": "const items = $input.all();\n  const storeFiles = $('StoreFile').all();\n  const results = [];\n\n  for (let i = 0; i < items.length; i++) {\n    const item = items[i];\n    const storeItem = storeFiles[i];\n\n    if (item.json.error) {\n      results.push({\n        json: {\n          isValid: false,\n          validationError: 'Gemini extraction failed',\n          messageId: storeItem ? storeItem.json.messageID : null\n        },\n        pairedItem: i\n      });\n      continue;\n    }\n\n    let response = item.json.content?.parts?.[0]?.text || item.json.text || '';\n    response = response.replace(/```json\\s*/g, '').replace(/```\\s*/g, '').trim();\n\n    try {\n      const data = JSON.parse(response);\n\n      const isValid =\n        (data.customer_tax_id === null || data.customer_tax_id?.length >= 10) &&\n        data.customer_company?.length > 0 &&\n        data.invoice_issued_date?.match(/\\d{4}-\\d{2}-\\d{2}/) &&\n        data.invoice_number?.length > 0 &&\n        data.invoice_amount_gross !== undefined &&\n        data.currency?.length >= 3 &&\n        data.category?.length > 0;\n\n      results.push({\n        json: {\n          ...data,\n          isValid: isValid,\n          validationError: isValid ? null : 'Missing or invalid required fields',\n          messageId: storeItem ? storeItem.json.messageID : null\n        },\n        binary: storeItem ? storeItem.binary : {},\n        pairedItem: i\n      });\n\n    } catch (e) {\n      results.push({\n        json: {\n          isValid: false,\n          validationError: 'JSON parse failed: ' + e.message,\n          rawResponse: response.substring(0, 200),\n          messageId: storeItem ? storeItem.json.messageID : null\n        },\n        pairedItem: i\n      });\n    }\n  }\n\n  return results;"
      },
