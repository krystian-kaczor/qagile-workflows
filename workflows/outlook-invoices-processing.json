      "id": "8dceda76-edaf-4072-ab75-30dc74123989",
      "name": "Get Months Folders INC",
      "credentials": {
        "microsoftOneDriveOAuth2Api": {
          "id": "TnsMOnxP20rBcpFv",
          "name": "Microsoft Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\n  const folders = Array.from($('Get Months Folders JDG').all());\n  const results = [];\n\n  for (let i = 0; i < inputItems.length; i++) {\n    const item = inputItems[i];\n    const invoiceData = item.json;\n    const invoiceMonth = invoiceData['invoice_issued_month-pl'];\n    const matchingFolder = folders.find(folder => folder.json.name === invoiceMonth);\n\n    if (!matchingFolder) continue;\n\n    const dateCompact = (invoiceData.invoice_issued_date || '').replace(/-/g, '');\n    const category = (invoiceData.category || 'unknown').toLowerCase();\n    const invNum = (invoiceData.invoice_number || '').replace(/[^a-zA-Z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').substring(0, 30);\n    const fileName = `${dateCompact}-${category}-${invNum}.pdf`;\n\n    const binaryKeys = item.binary ? Object.keys(item.binary) : [];\n    const binaryKey = binaryKeys.find(k => k === 'currentFile') || binaryKeys[0];\n    const binaryData = binaryKey ? item.binary[binaryKey] : null;\n\n    const renamedBinary = binaryData ? {\n      currentFile: { ...binaryData, fileName: fileName }\n    } : {};\n\n    results.push({\n      json: {\n        folderId: matchingFolder.json.id,\n        folderName: matchingFolder.json.name,\n        folderPath: matchingFolder.json.webUrl,\n        fileName: fileName,\n        messageID: invoiceData.messageId,\n        supplier_company: invoiceData.supplier_company,\n        customer_tax_id: invoiceData.customer_tax_id,\n        customer_company: invoiceData.customer_company,\n        invoice_number: invoiceData.invoice_number,\n        invoice_issued_date: invoiceData.invoice_issued_date,\n        invoice_amount_net: invoiceData.invoice_amount_net,\n        invoice_amount_tax: invoiceData.invoice_amount_tax,\n        invoice_amount_gross: invoiceData.invoice_amount_gross,\n        currency: invoiceData.currency,\n        category: invoiceData.category\n      },\n      binary: renamedBinary\n    });\n  }\n\n  return results;"
      },
